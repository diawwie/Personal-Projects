PROBLEM 4: 
Create a statement-level trigger to secure the DIA_PASTRIES menu. 
Restrict any INSERT, UPDATE, or DELETE operations from happening during 
the weekend (Saturday or Sunday).

CREATE OR REPLACE TRIGGER trg_secure_pastries
BEFORE INSERT OR UPDATE OR DELETE ON DIA_PASTRIES
BEGIN
    -- Prevent menu item alterations on weekends
    IF TRIM(TO_CHAR(SYSDATE, 'DAY')) IN ('SATURDAY', 'SUNDAY') THEN
        RAISE_APPLICATION_ERROR(-20003, 'Operation not allowed. You may only alter the Pastry Menu during weekday business hours.');
    END IF;
END;
/



PROBLEM 3: Triggers (Row-Level and Statement-Level) 
Create a row-level trigger that prevents an employee's salary from being decreased by more than 20% during an UPDATE. Test the trigger using at least one SQL statement.

-- ROW-LEVEL TRIGGER 1: Prevent Drastic Salary Cuts
CREATE OR REPLACE TRIGGER trg_prevent_salary_cut
BEFORE UPDATE OF salary ON DIA_EMPLOYEES
FOR EACH ROW
BEGIN
    -- Check if the new salary is drastically lower than the old salary
    IF :NEW.salary < (:OLD.salary * 0.8) THEN
        RAISE_APPLICATION_ERROR(-20002, 'Salary decrease cannot exceed 20% of the current salary!');
    END IF;
END;
/


-- ROW-LEVEL TRIGGER 2: Prevent Deleting Completed Orders
CREATE OR REPLACE TRIGGER trg_prevent_del_ord
BEFORE DELETE ON DIA_ORDERS
FOR EACH ROW
BEGIN
    IF :OLD.status = 'COMPLETED' THEN
        RAISE_APPLICATION_ERROR(-20004, 'Cannot delete an order that has already been COMPLETED.');
    END IF;
END;
/



-- STATEMENT-LEVEL TRIGGER 1: Audit New Hires
CREATE OR REPLACE TRIGGER trg_employee_audit
AFTER INSERT ON DIA_EMPLOYEES
BEGIN
    DBMS_OUTPUT.PUT_LINE('AUDIT: A new employee has been added to the Dolce Vita system.');
END;
/


